// esperado: 25
// 'continuar' em 'faca/enquanto' salta para a re-avaliacao da condicao.
// Iteracao: i=1..10, soma os impares; i e' decrementado/incrementado pelo
// proprio corpo. Ao final, i == 11 e a condicao 'i <= 10' e' falsa.
funcao inteiro principal() {
    inteiro i = 0;
    inteiro soma = 0;
    faca {
        i = i + 1;
        se (i % 2 == 0) { continuar; }
        soma = soma + i;
    } enquanto (i <= 9);
    retornar soma;   // 1+3+5+7+9 = 25
}
