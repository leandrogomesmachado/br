// Tabuada 3x3 imprimindo so os produtos, um por linha.
// Matriz (i=1..3, j=1..3): 1 2 3 2 4 6 3 6 9
funcao inteiro principal() {
    para (inteiro i = 1; i <= 3; i = i + 1) {
        para (inteiro j = 1; j <= 3; j = j + 1) {
            escrever_inteiro(i * j);
            escrever_caractere('\n');
        }
    }
    retornar 0;
}
