// Atribuicoes compostas bitwise: &= |= ^= <<= >>=
// esperado: 42
funcao inteiro principal() {
    inteiro a = 255;
    a &= 240;       // 240
    a |= 7;         // 247
    a ^= 5;         // 242
    a >>= 1;        // 121
    a <<= 1;        // 242
    se (a != 242) { retornar 1; }

    // Em elemento de vetor
    inteiro v[3];
    v[0] = 12;
    v[0] |= 3;      // 15
    v[0] &= 14;     // 14
    se (v[0] != 14) { retornar 2; }

    // Via ponteiro (*p)
    inteiro y = 8;
    inteiro * p = &y;
    *p <<= 2;       // y == 32
    *p |= 1;        // y == 33
    se (y != 33) { retornar 3; }

    retornar 42;
}
