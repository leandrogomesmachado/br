// Constroi uma palavra em um vetor de caractere e a imprime byte a byte.
funcao inteiro principal() {
    caractere letras[5];
    letras[0] = 'B';
    letras[1] = 'r';
    letras[2] = 'a';
    letras[3] = 's';
    letras[4] = '!';
    inteiro i = 0;
    enquanto (i < 5) {
        escrever_caractere(letras[i]);
        i = i + 1;
    }
    escrever_caractere('\n');
    retornar 0;
}
